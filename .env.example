# Authentication (Better Auth)
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET= # Linux/macOS: openssl rand -hex 32

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=common

# Storage
# Persistent settings/stats use the `APP_SETTINGS_KV` Cloudflare KV binding from `wrangler.jsonc`.

# News API (optional)
NEWS_API_BASE_URL=https://news.ravelloh.top

# Advertising (optional)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_VERCEL_ANALYTICS=

# Observability (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_LOG_LEVEL=debug

# Build options (optional)
ANALYZE=false
