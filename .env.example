# Authentication (Better Auth)
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET= # Linux/macOS: openssl rand -hex 32

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=common

# Storage
# Persistent settings/stats use the `APP_SETTINGS_KV` Cloudflare KV binding from `wrangler.jsonc`.

# News API (optional)
NEWS_API_BASE_URL=https://news.ravelloh.top

# Advertising (optional, preferred Vite naming)
VITE_ADSENSE_CLIENT_ID=
VITE_ADSENSE_SLOT_SIDEBAR=
VITE_ADSENSE_SLOT_HEADER=
VITE_ADSENSE_SLOT_FOOTER=
VITE_ADSENSE_SLOT_INLINE=

# Analytics (optional, preferred Vite naming)
VITE_GA_ID=
VITE_VERCEL_ANALYTICS=

# Observability (optional, preferred Vite naming)
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
VITE_LOG_LEVEL=debug

# Build options (optional)
ANALYZE=false
