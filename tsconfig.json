{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "next-intl": ["./src/shims/next-intl.tsx"],
      "next-intl/server": ["./src/shims/next-intl-server.ts"],
      "next/navigation": ["./src/shims/next-navigation.tsx"],
      "next/link": ["./src/shims/next-link.tsx"],
      "next/image": ["./src/shims/next-image.tsx"],
      "next/dynamic": ["./src/shims/next-dynamic.tsx"],
      "next/cache": ["./src/shims/next-cache.ts"],
      "next-themes": ["./src/shims/next-themes.tsx"]
    },
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "*.js",
    "*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "messages/**/*.json",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "types/**/*.ts",
    "worker/**/*.ts",
    "config/**/*.ts",
    "playwright.config.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "worker/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "public",
    ".next",
    "app",
    "i18n",
    "i18n.ts",
    "next-env.d.ts",
    "proxy.ts",
    "lib/i18n.ts"
  ]
}
