{
  "name": "shaking-head-news",
  "description": "Shake your head while watching the news - A modern web app with daily news and neck health features",
  "version": "2.3.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ohengcom/shaking-head-news.git"
  },
  "keywords": [
    "nextjs",
    "react",
    "news",
    "health",
    "cervical spondylosis",
    "web app"
  ],
  "author": "ohengcom <ohengcom@users.noreply.github.com>",
  "license": "MPL-2.0",
  "bugs": {
    "url": "https://github.com/ohengcom/shaking-head-news/issues"
  },
  "homepage": "https://github.com/ohengcom/shaking-head-news",
  "type": "module",
  "packageManager": "npm@11.5.2",
  "scripts": {
    "prepare": "husky || true",
    "dev": "vinext dev --port 3001",
    "build": "vinext build",
    "start": "vinext start",
    "dev:next": "next dev --turbo",
    "build:next": "next build",
    "start:next": "next start",
    "build:analyze": "ANALYZE=true next build",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "dev:vinext": "vinext dev --port 3001",
    "build:vinext": "vinext build",
    "start:vinext": "vinext start"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.4",
    "@swc/helpers": "^0.5.19",
    "@tailwindcss/postcss": "^4.2.1",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.5.5",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.4",
    "@fast-check/vitest": "^0.3.0",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-rsc": "^0.5.21",
    "@vitest/coverage-v8": "^4.0.16",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "postcss": "^8.5.8",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "vinext": "^0.0.25",
    "vite": "^7.3.1",
    "vitest": "^4.0.16",
    "wrangler": "^4.71.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@hono/node-server": "^1.19.11",
    "@mrleebo/prisma-ast": "^0.14.0",
    "rollup": "^4.59.0",
    "chevrotain": "^11.2.0",
    "hono": "^4.12.5",
    "lodash": "^4.17.23",
    "webpack": "^5.105.4",
    "@typescript-eslint/parser": {
      "eslint": "$eslint"
    },
    "@typescript-eslint/eslint-plugin": {
      "eslint": "$eslint"
    }
  }
}
